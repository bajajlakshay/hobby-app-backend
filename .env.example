# Production secrets for docker-compose.prod.yml.
# Copy to ".env" on the server and fill in real values. Never commit ".env".

# --- PostgreSQL ---
POSTGRES_USER=hobbyapp
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=hobbyapp

# --- JWT ---
# Generate a long random key, e.g.:  openssl rand -hex 64
JWT_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=HobbyApp
JWT_AUDIENCE=HobbyAppClient

# --- Email (SMTP) for OTP verification ---
# Provider-agnostic. Example for Gmail: Host=smtp.gmail.com, Port=587,
# Username=your@gmail.com, Password=<16-char app password>, UseStartTls=true.
# Leave EMAIL_HOST empty to disable sending (the OTP is logged instead).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@hobbyapp.tech
EMAIL_FROM_NAME=HobbyApp
EMAIL_USE_STARTTLS=true
