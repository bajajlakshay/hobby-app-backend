# Production secrets for docker-compose.prod.yml.
# Copy to ".env" on the server and fill in real values. Never commit ".env".

# --- PostgreSQL ---
POSTGRES_USER=hobbyapp
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=hobbyapp

# --- JWT ---
# Generate a long random key, e.g.:  openssl rand -hex 64
JWT_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=HobbyApp
JWT_AUDIENCE=HobbyAppClient
